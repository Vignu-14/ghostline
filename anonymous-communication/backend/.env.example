PORT=3000
ENVIRONMENT=development
ALLOWED_ORIGIN=http://localhost:5173

# For some IPv4-only networks, Supabase requires the Session pooler string instead of the direct db.<project-ref>.supabase.co host.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/anonymous_communication?sslmode=disable
DB_MAX_CONNECTIONS=25
DB_MIN_CONNECTIONS=5
DB_MAX_CONN_LIFETIME_MINUTES=60
DB_MAX_CONN_IDLE_MINUTES=15
DB_HEALTH_CHECK_SECONDS=30
DB_CONNECT_TIMEOUT_SECONDS=5

JWT_SECRET=change-me-for-local-development
JWT_EXPIRATION_MINUTES=15
AUTH_COOKIE_NAME=auth_token
COOKIE_SECURE=false

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
STORAGE_BUCKET_NAME=user-uploads
